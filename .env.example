# ─────────────────────────────────────────────────
# HepsiGaming — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# ─────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=hepsigaming
POSTGRES_USER=hgadmin
POSTGRES_PASSWORD=GUCLU_SIFRE_GIRIN

# Redis
REDIS_URL=redis://redis:6379/0

# FastAPI Secret Key (python -c "import secrets; print(secrets.token_hex(32))" ile üretin)
SECRET_KEY=BURAYA_GIZLI_ANAHTAR
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=https://hepsigaming.com
NEXT_PUBLIC_SITE_NAME=HepsiGaming

# Web Push (VAPID Keys - web-push-codelab.glitch.me adresinden üretin)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@hepsigaming.com

# Affiliate Kodları
AMAZON_AFFILIATE_TAG=hepsigaming-21
TRENDYOL_AFFILIATE_ID=

# Sosyal Medya (Admin panelden değiştirilebilir, buradaki default)
SOCIAL_INSTAGRAM=
SOCIAL_YOUTUBE=
SOCIAL_DISCORD=
SOCIAL_TWITCH=
SOCIAL_TIKTOK=
SOCIAL_X=

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Environment
ENVIRONMENT=development
DEBUG=true
